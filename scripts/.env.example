# numbrs-collector environment variables
# Copy this file to scripts/.env and fill in real values
# NEVER commit scripts/.env — it's in .gitignore

NUMBRS_API_KEY="nmbr_your_api_key_here"
NUMBRS_INGEST="https://your-project.supabase.co/functions/v1/ingest"
NUMBRS_SUPABASE_SERVICE_KEY="your_supabase_service_role_jwt_here"
NUMBRS_SUPABASE_URL="https://your-project.supabase.co"
JELLYFIN_URL="http://localhost:8096"
JELLYFIN_KEY="your_jellyfin_api_key_here"
PLEX_TOKEN="your_plex_token_here"
PLEX_URL="https://your-plex-server.plex.direct:32400"
