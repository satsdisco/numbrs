# numbrs-collector environment variables
# Copy this file to scripts/.env and fill in real values
# NEVER commit scripts/.env — it's in .gitignore

NUMBRS_API_KEY="nmbr_your_api_key_here"
NUMBRS_INGEST="https://your-project.supabase.co/functions/v1/ingest"
NUMBRS_SUPABASE_SERVICE_KEY="your_supabase_service_role_jwt_here"
NUMBRS_SUPABASE_URL="https://your-project.supabase.co"
JELLYFIN_URL="http://localhost:8096"
JELLYFIN_KEY="your_jellyfin_api_key_here"
PLEX_TOKEN="your_plex_token_here"
PLEX_URL="https://your-plex-server.plex.direct:32400"

# ── speedtest-collector.sh ────────────────────────────────────────────────────
# Install: brew install speedtest-cli (Ookla) or: pip install speedtest-cli
# No extra vars needed — uses NUMBRS_API_KEY + NUMBRS_INGEST above

# ── listenbrainz-collector.sh ─────────────────────────────────────────────────
# LISTENBRAINZ_USER is required; LISTENBRAINZ_TOKEN is optional (public data works without it)
LISTENBRAINZ_USER="your_listenbrainz_username"
LISTENBRAINZ_TOKEN=""

# ── calendar-collector.sh ─────────────────────────────────────────────────────
# Requires: gog CLI (already installed)
# No extra vars needed — uses NUMBRS_API_KEY + NUMBRS_INGEST above

# ── pihole-collector.sh ───────────────────────────────────────────────────────
# PIHOLE_HOST: hostname or IP of your Pi-hole (no http://, no trailing slash)
# PIHOLE_TOKEN: your Pi-hole API token — find it at: Settings → API / Web interface → Show API token
PIHOLE_HOST="192.168.1.2"
PIHOLE_TOKEN=""
