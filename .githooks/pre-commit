#!/bin/bash
# Pre-commit hook: scan for leaked secrets before committing
# Install: git config core.hooksPath .githooks

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

ISSUES=0

for FILE in $STAGED_FILES; do
  # Skip binary files, .env.example, and the hook itself
  [[ "$FILE" == *.env.example ]] && continue
  [[ "$FILE" == .githooks/* ]] && continue
  [[ ! -f "$FILE" ]] && continue
  file "$FILE" | grep -q "text" || continue

  CONTENT=$(git show ":$FILE" 2>/dev/null) || continue

  # JWT tokens (eyJ...)
  if echo "$CONTENT" | grep -qE 'eyJ[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{20,}'; then
    echo -e "${RED}🚨 BLOCKED:${NC} Possible JWT token found in ${YELLOW}$FILE${NC}"
    ISSUES=$((ISSUES + 1))
  fi

  # Supabase service role keys
  if echo "$CONTENT" | grep -qiE '(supabase.*service.*key|service_role.*=).*eyJ'; then
    echo -e "${RED}🚨 BLOCKED:${NC} Supabase service role key in ${YELLOW}$FILE${NC}"
    ISSUES=$((ISSUES + 1))
  fi

  # Generic API keys (long hex/alphanumeric strings assigned to variables)
  if echo "$CONTENT" | grep -qE '(API_KEY|SECRET|PASSWORD|TOKEN|PRIVATE_KEY)\s*=\s*"[a-zA-Z0-9_-]{20,}"'; then
    echo -e "${RED}🚨 BLOCKED:${NC} Possible hardcoded secret in ${YELLOW}$FILE${NC}"
    ISSUES=$((ISSUES + 1))
  fi

  # AWS keys
  if echo "$CONTENT" | grep -qE 'AKIA[0-9A-Z]{16}'; then
    echo -e "${RED}🚨 BLOCKED:${NC} Possible AWS access key in ${YELLOW}$FILE${NC}"
    ISSUES=$((ISSUES + 1))
  fi

  # Private keys
  if echo "$CONTENT" | grep -q 'BEGIN.*PRIVATE KEY'; then
    echo -e "${RED}🚨 BLOCKED:${NC} Private key found in ${YELLOW}$FILE${NC}"
    ISSUES=$((ISSUES + 1))
  fi
done

if [[ $ISSUES -gt 0 ]]; then
  echo ""
  echo -e "${RED}✋ Commit blocked: $ISSUES potential secret(s) detected.${NC}"
  echo "  → Move secrets to environment variables or .env files"
  echo "  → To bypass (if false positive): git commit --no-verify"
  exit 1
fi

exit 0
